# ============================================================================
# Smart Scheduler Agent — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# (On Vercel, add these in Project Settings → Environment Variables instead.)
# ============================================================================

# --- 1. Gemini (Google AI Studio) -------------------------------------------
# Get a FREE key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Live (voice) model. Must be a model that supports bidiGenerateContent.
# List valid ones for your key with:
#   curl "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_API_KEY" \
#     | grep -B2 bidiGenerateContent
# Recommended: gemini-3.1-flash-live-preview (robust audio + tool-calling).
# NOTE: native-audio models (gemini-2.5-flash-native-audio-*) sound great but
# had tool-calling issues in testing — prefer the *-live-* models here.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# --- 2. Google Calendar (Service Account) -----------------------------------
# Create a service account in Google Cloud, enable the Calendar API, download
# its JSON key, then paste the two fields below.
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value. Keep the literal \n escapes on one line, e.g.
# "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# The calendar to read/write. Share THIS calendar with the service account
# email above (with "Make changes to events"). Usually your Google email.
GOOGLE_CALENDAR_ID=you@gmail.com

# --- 3. Agent behavior config -----------------------------------------------
# IANA timezone the agent schedules in (e.g. America/New_York, Asia/Kolkata).
AGENT_TIMEZONE=America/New_York

# Working hours (24h, local to AGENT_TIMEZONE) the agent will offer slots in.
WORK_DAY_START=9
WORK_DAY_END=18

# --- 4. Confirmation email (Resend) — OPTIONAL ------------------------------
# Booking works without this; if set, a confirmation email is sent on booking.
# Get a free key at https://resend.com/api-keys (free tier: 100 emails/day).
RESEND_API_KEY=
# In Resend test mode (no verified domain) keep this sender and email your OWN
# address only. With a verified domain, use your own from-address.
FROM_EMAIL=Smart Scheduler <onboarding@resend.dev>
# Recipient of the confirmation. Defaults to GOOGLE_CALENDAR_ID if it's an email.
NOTIFY_EMAIL=
